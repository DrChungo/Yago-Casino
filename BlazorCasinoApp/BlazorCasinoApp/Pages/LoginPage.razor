@page "/login"
@using Chaos.BlazorCasinoApp.Service
@using Chaos.Shared.RequestEntity
@inject AuthBackOfficeService AuthService
@inject NavigationManager Navigation

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">🎰 BackOffice Login</h2>
        <p class="auth-subtitle">Acceso exclusivo para administradores</p>

        <EditForm Model="@_request" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Email</label>
                <InputText class="form-control" @bind-Value="_request.Email"
                           placeholder="admin@casino.com" />
            </div>

            <div class="form-group mt-3">
                <label>Contraseña</label>
                <InputText type="password" class="form-control"
                           @bind-Value="_request.Password"
                           placeholder="••••••••" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger mt-3">
                    ⚠️ @_errorMessage
                </div>
            }

            <button type="submit" class="btn btn-primary w-100 mt-4" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Ingresando...</span>
                }
                else
                {
                    <span>Iniciar Sesión</span>
                }
            </button>
        </EditForm>

        <div class="mt-3 text-center">
            <a href="/register">¿No tienes cuenta? Registrarse</a>
        </div>
    </div>
</div>

@code {
    private readonly LoginBackOfficeRequest _request = new();
    private string? _errorMessage;
    private bool _isLoading;

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await AuthService.LoginAsync(_request);

            if (result?.Token is not null)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                _errorMessage = result?.Message ?? "Error al iniciar sesión.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}