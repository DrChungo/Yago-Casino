@page "/RouletteGamePage/edit/{Id:guid}"
@using Chaos.BlazorCasinoApp.IApiService
@using Chaos.Shared.ResponseEntity
@using Chaos.Shared.RequestEntity
@inject IRouletteGameConfigService RouletteService
@inject NavigationManager Navigation

<PageTitle>Editar Configuración — Roulette Game</PageTitle>

<div class="casino-page">

    <div class="casino-form-header">
        <button class="btn-casino-secondary" @onclick="GoBack">← Volver</button>
        <h4>✏️ Editar Configuración Roulette Game</h4>
    </div>

    @if (isLoading)
    {
        <div class="casino-loading">
            <div class="casino-spinner" role="status">🎰</div>
            <p class="text-gold">Cargando datos...</p>
        </div>
    }
    else
    {
        @if (errorMessage is not null)
        {
            <div class="alert alert-danger">⚠️ @errorMessage</div>
        }

        <div class="card">
            <div class="card-body">

                <div class="casino-id-box">
                    <small>ID de Configuración</small>
                    <span>@Id</span>
                </div>

                <div class="form-group">
                    <label class="form-label">Nombre de Mesa</label>
                    <input class="form-control" @bind="tableName" />
                </div>

                <div class="form-group">
                    <label class="form-label">Tipo de Ruleta</label>
                    <input class="form-control" @bind="rouletteType" />
                </div>

                <div class="form-group">
                    <label class="form-label">Total de Números</label>
                    <input class="form-control" type="number" @bind="totalNumbers" />
                </div>

                <div class="casino-toggle-row">
                    <label class="form-label">Tiene Zero (0)</label>
                    <button type="button"
                            class="casino-toggle-btn @(hasZero ? "badge-casino-active" : "badge-casino-inactive")"
                            @onclick="() => hasZero = !hasZero">
                        @(hasZero ? "✅ Sí" : "❌ No")
                    </button>
                </div>

                <div class="casino-toggle-row">
                    <label class="form-label">Tiene Doble Zero (00)</label>
                    <button type="button"
                            class="casino-toggle-btn @(hasDoubleZero ? "badge-casino-active" : "badge-casino-inactive")"
                            @onclick="() => hasDoubleZero = !hasDoubleZero">
                        @(hasDoubleZero ? "✅ Sí" : "❌ No")
                    </button>
                </div>

                <div class="casino-toggle-row">
                    <label class="form-label">Estado</label>
                    <button type="button"
                            class="casino-toggle-btn @(isActive ? "badge-casino-active" : "badge-casino-inactive")"
                            @onclick="() => isActive = !isActive">
                        @(isActive ? "● Activo" : "● Inactivo")
                    </button>
                </div>

                <div class="casino-form-actions">
                    <button class="btn-casino-secondary" @onclick="GoBack">✖ Cancelar</button>
                    <button class="btn-casino-primary" @onclick="HandleEdit" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="casino-spinner-sm">🎰</span>
                        }
                        💾 Actualizar
                    </button>
                </div>

            </div>
        </div>
    }

</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private string tableName = "";
    private string rouletteType = "";
    private int totalNumbers = 37;
    private bool hasZero = true;
    private bool hasDoubleZero = false;
    private bool isActive = true;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var config = await RouletteService.GetByIdAsync(Id);

            if (config is not null)
            {
                tableName = config.TableName;
                rouletteType = config.RouletteType;
                hasZero = config.HasZero;
                hasDoubleZero = config.HasDoubleZero;
                totalNumbers = config.TotalNumbers;
                isActive = config.IsActive;
            }
            else
            {
                errorMessage = "No se encontró la configuración.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleEdit()
    {
        if (string.IsNullOrWhiteSpace(tableName))
        {
            errorMessage = "El nombre de la mesa es obligatorio.";
            return;
        }

        try
        {
            isSaving = true;
            errorMessage = null;

            var request = new RouletteGameConfigRequest
            {
                TableName = tableName,
                RouletteType = rouletteType,
                HasZero = hasZero,
                HasDoubleZero = hasDoubleZero,
                TotalNumbers = totalNumbers,
                IsActive = isActive
            };

            await RouletteService.UpdateAsync(Id, request);
            Navigation.NavigateTo("/RouletteGamePage");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al actualizar: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/RouletteGamePage");
}