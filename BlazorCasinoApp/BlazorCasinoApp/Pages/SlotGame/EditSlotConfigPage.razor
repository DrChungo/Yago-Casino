@page "/slot-config/edit/{ConfigId:guid}"

@using Chaos.BlazorCasinoApp.IApiService.Slots
@using Chaos.Shared.RequestEntity.SlotGame

@inject ISlotGameService SlotGameConfigService
@inject NavigationManager Nav

<PageTitle>Editar Configuración — Slot Game</PageTitle>

<div class="casino-page">

    <div class="casino-form-header">
        <button class="btn-casino-secondary" @onclick="GoBack">← Volver</button>
        <h4>✏️ Editar Configuración de Slot</h4>
    </div>

    @if (isLoading)
    {
        <div class="casino-loading">
            <div class="casino-spinner" role="status">🛞</div>
            <p class="text-gold">Cargando datos...</p>
        </div>
    }
    else if (errorMessage is not null)
    {
        <div class="alert alert-danger">⚠️ @errorMessage</div>
    }
    else
    {
        <div class="card">
            <div class="card-body">

                <div class="casino-id-box">
                    <small>ID de Configuración</small>
                    <span>@ConfigId</span>
                </div>

                <EditForm Model="request" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="form-group">
                        <label class="form-label">Nombre Máquina</label>
                        <InputText class="form-control" @bind-Value="request.MachineName" />
                        <ValidationMessage For="() => request.MachineName" />
                    </div>

                    <div class="casino-form-row">
                        <div class="form-group">
                            <label class="form-label">Multiplicador</label>
                            <InputNumber class="form-control" @bind-Value="request.Multiplier" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Número de Reels</label>
                            <InputNumber class="form-control" @bind-Value="request.NumberOfReels" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Número de Rows</label>
                            <InputNumber class="form-control" @bind-Value="request.NumberOfRows" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">PayLines</label>
                        <InputNumber class="form-control" @bind-Value="request.PayLines" />
                    </div>

                    <div class="casino-toggle-row">
                        <button type="button"
                                class="casino-toggle-btn @(request.IsActive ? "badge-casino-active" : "badge-casino-inactive")"
                                @onclick="() => request.IsActive = !request.IsActive">
                            @if (request.IsActive)
                            {
                                <span>● Activo</span>
                            }
                            else
                            {
                                <span>● Inactivo</span>
                            }
                        </button>
                    </div>

                    <div class="casino-form-actions">
                        <button type="button" class="btn-casino-secondary" @onclick="GoBack">
                            ✖ Cancelar
                        </button>
                        <button type="submit" class="btn-casino-primary" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="casino-spinner-sm">🎰</span>
                            }
                            💾 Guardar Cambios
                        </button>
                    </div>

                </EditForm>
            </div>
        </div>
    }

</div>

@code {
    [Parameter] public Guid ConfigId { get; set; }

    private UpdateSlotGameConfigRequest request = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var config = await SlotGameConfigService.GetByIdAsync(ConfigId);
            request = new UpdateSlotGameConfigRequest
            {
                MachineName = config.MachineName,
                Multiplier = config.Multiplier,
                NumberOfReels = config.NumberOfReels,
                NumberOfRows = config.NumberOfRows,
                PayLines = config.PayLines,
                IsActive = config.IsActive
            };
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar configuración: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            await SlotGameConfigService.UpdateAsync(ConfigId, request);
            GoBack();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar cambios: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/SlotGamePage");
}